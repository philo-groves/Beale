{
  "name": "beale",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "description": "Beale authorized vulnerability research workbench",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:benchmark": "vitest run tests/benchmark-runner.test.ts",
    "test:benchmark:live": "BEALE_BENCHMARK_LIVE_DOCKER=1 vitest run tests/benchmark-live.test.ts",
    "test:plan": "vitest run tests/plan-conformance.test.ts",
    "test:executor": "vitest run tests/executor-manager.test.ts",
    "test:firecracker": "vitest run tests/firecracker-vmctl.test.ts",
    "test:firecracker:live": "BEALE_FIRECRACKER_LIVE_TEST=1 BEALE_VMCTL_COMMAND=$(command -v node) BEALE_VMCTL_ARGS_JSON='[\"scripts/firecracker-vmctl.mjs\",\"--config\",\".beale/firecracker/config.json\"]' vitest run tests/firecracker-live.test.ts",
    "test:openai:live": "BEALE_LIVE_OPENAI_TEST=1 vitest run tests/openai-live.test.ts",
    "test:openai-firecracker:live": "BEALE_LIVE_OPENAI_FIRECRACKER_TEST=1 BEALE_VMCTL_COMMAND=$(command -v node) BEALE_VMCTL_ARGS_JSON='[\"scripts/firecracker-vmctl.mjs\",\"--config\",\".beale/firecracker/config.json\"]' vitest run tests/openai-firecracker-live.test.ts",
    "build": "npm run typecheck && electron-vite build",
    "sandbox:docker:build": "docker build -t beale-sandbox-toolchain:local docker/sandbox-toolchain",
    "firecracker:init": "node scripts/firecracker-setup.mjs --init",
    "firecracker:doctor": "node scripts/firecracker-setup.mjs --doctor",
    "firecracker:install-binary": "node scripts/firecracker-setup.mjs --install-binary",
    "firecracker:install-ci-images": "node scripts/firecracker-setup.mjs --install-ci-images",
    "firecracker:install-privileged-helper": "node scripts/firecracker-setup.mjs --install-privileged-helper"
  },
  "dependencies": {
    "d3-force": "^3.0.0",
    "lucide-react": "^0.554.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "typescript": "^5.9.3",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/d3-force": "^3.0.10",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.6",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.1.4",
    "electron": "^41.3.0",
    "electron-vite": "^5.0.0",
    "vite": "^7.3.2",
    "vitest": "^4.1.5"
  }
}
